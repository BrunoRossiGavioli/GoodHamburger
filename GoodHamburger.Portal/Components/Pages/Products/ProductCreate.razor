@page "/products/create"
@attribute [Authorize(Roles = Roles.Administrador)]

@using GoodHamburger.Portal.Services.Products
@using GoodHamburger.Shared.DTOs.Products
@using GoodHamburger.Shared.Enums
@using System.ComponentModel.DataAnnotations

@inject ProductService ProductService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Novo Produto - Good Hamburger</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudText Typo="Typo.h4" Class="mb-4">Novo Produto</MudText>

    <MudCard>
        <MudCardContent>
            <EditForm Model="@_model" OnValidSubmit="CreateAsync">
                <DataAnnotationsValidator />
                
                <MudGrid>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.Name"
                                      Label="Nome"
                                      Required="true"
                                      For="@(() => _model.Name)" />
                        <ValidationMessage For="@(() => _model.Name)" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.Description"
                                      Label="Descrição"
                                      Lines="3"
                                      Required="true"
                                      For="@(() => _model.Description)" />
                        <ValidationMessage For="@(() => _model.Description)" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect @bind-Value="_model.Type"
                                   Label="Tipo"
                                   Required="true"
                                   For="@(() => _model.Type)"
                                   AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem Value="@ProductType.Sandwich">Lanche</MudSelectItem>
                            <MudSelectItem Value="@ProductType.Drink">Bebida</MudSelectItem>
                            <MudSelectItem Value="@ProductType.Fries">Batata</MudSelectItem>
                        </MudSelect>
                        <ValidationMessage For="@(() => _model.Type)" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField @bind-Value="_model.Price"
                                         Label="Preço"
                                         Format="C2"
                                         Required="true"
                                         Min="0"
                                         Step="0.01m"
                                         For="@(() => _model.Price)" />
                        <ValidationMessage For="@(() => _model.Price)" />
                    </MudItem>
                </MudGrid>

                <MudGrid Class="mt-4">
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="GoBack"
                                   FullWidth="true">
                            Voltar
                        </MudButton>
                    </MudItem>
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   ButtonType="ButtonType.Submit"
                                   Disabled="@_isSaving"
                                   FullWidth="true">
                            @(_isSaving ? "Salvando..." : "Salvar")
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private ProductCreateModel _model = new();
    private bool _isSaving;

    private class ProductCreateModel
    {
        [Required(ErrorMessage = "O nome é obrigatório")]
        [StringLength(100, ErrorMessage = "Nome deve ter no máximo 100 caracteres")]
        public string Name { get; set; } = "";

        [Required(ErrorMessage = "A descrição é obrigatória")]
        [StringLength(500, ErrorMessage = "Descrição deve ter no máximo 500 caracteres")]
        public string Description { get; set; } = "";

        [Required(ErrorMessage = "O tipo é obrigatório")]
        public ProductType Type { get; set; } = ProductType.Sandwich;

        [Required(ErrorMessage = "O preço é obrigatório")]
        [Range(0.01, 999999.99, ErrorMessage = "Preço deve ser maior que zero")]
        public decimal Price { get; set; }
    }

    private void GoBack() => Navigation.NavigateTo("/products");

    private async Task CreateAsync()
    {
        try
        {
            _isSaving = true;
            var dto = new CreateProductDto(_model.Name, _model.Description, _model.Type, _model.Price);
            await ProductService.CreateAsync(dto);
            Snackbar.Add("Produto cadastrado com sucesso!", Severity.Success);
            Navigation.NavigateTo("/products");
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Erro ao cadastrar produto: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }
}