@page "/"
@attribute [Authorize(Roles = $"{Roles.Administrador},{Roles.Funcionario}")]

@using GoodHamburger.Portal.Components.Pages.Orders
@using GoodHamburger.Portal.Components.Pages.Products
@using GoodHamburger.Portal.Services.Products
@using GoodHamburger.Portal.Services.Orders
@using GoodHamburger.Shared.Exceptions.BusinessRules
@using GoodHamburger.Shared.Models.Customers
@using GoodHamburger.Shared.Models.Products
@using GoodHamburger.Shared.Models.PurchaseOrders
@using GoodHamburger.Shared.DTOs.PurchaseOrders
@using GoodHamburger.Shared.Enums
@using GoodHamburger.Shared.Extensions.Models

@inject ProductService ProductService
@inject OrderService OrderService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Novo Pedido - Good Hamburger</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @if (_isLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mt-4" />
    }
    else if (_productGroups is null || !_productGroups.Any())
    {
        <MudAlert Severity="Severity.Warning">Nenhum produto disponível no momento.</MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="8">
                <MenuSection ProductGroups="_productGroups"
                             OnAddProduct="AddProductAsync"
                             Items="_items" />
            </MudItem>
            <MudItem xs="12" md="4">
                <OrderSummary Items="_items"
                              OnClear="ClearOrder"
                              OnCreateOrder="CreateOrderAsync"
                              OnRemoveItem="RemoveItemAsync"
                              Discount="_discount"
                              Subtotal="_subtotal"
                              Total="_total"
                              CustomerNameChanged="@(v => _customerName = v)"
                              CustomerPhoneChanged="@(v => _customerPhone = v)"
                              CustomerAddressChanged="@(v => _customerAddress = v)"
                              UseExistingCustomerChanged="@(v => _useExistingCustomer = v)"
                              OnSelectExistingCustomer="SelectExistingCustomer" />
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private List<OrderItem> _items = new();
    private IEnumerable<IGrouping<ProductType, Product>>? _productGroups;
    private bool _isLoading = true;
    private decimal _subtotal, _discount, _total;
    private Guid? _customerId;
    private string _customerName = string.Empty;
    private string _customerPhone = string.Empty;
    private string _customerAddress = string.Empty;
    private bool _useExistingCustomer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadProducts();
            StateHasChanged();
        }
    }

    private async Task LoadProducts()
    {
        try
        {
            _isLoading = true;
            StateHasChanged();
            var products = await ProductService.GetAllAsync();
            _productGroups = products.GroupBy(p => p.Type).OrderBy(g => (int)g.Key);
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Erro ao carregar produtos: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AddProductAsync(Product product)
    {
        // Validações de negócio
        if (_items.Any(i => i.Product.Id == product.Id))
        {
            Snackbar.Add("Este produto já foi adicionado.", Severity.Warning);
            return;
        }

        // Valida regra de tipo único
        var newItems = new List<OrderItem>(_items)
        {
            new OrderItem(1, string.Empty, product)
        };

        try
        {
            newItems.ThrowIfInvalidOrder();
        }
        catch (OrderException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
            return;
        }

        _items.Add(new OrderItem(1, string.Empty, product));
        UpdateTotals();
    }

    private async Task RemoveItemAsync(OrderItem item)
    {
        _items.Remove(item);
        UpdateTotals();
    }

    private void ClearOrder()
    {
        _items.Clear();
        UpdateTotals();
        // Limpar dados do cliente também
        _customerId = null;
        _customerName = string.Empty;
        _customerPhone = string.Empty;
        _customerAddress = string.Empty;
        _useExistingCustomer = false;
    }

    private async Task CreateOrderAsync()
    {
        if (!_items.Any())
        {
            Snackbar.Add("Adicione pelo menos um item ao pedido.", Severity.Warning);
            return;
        }

        try
        {
            var dto = new CreateOrderDto(
                CustomerId: _customerId,
                CustomerName: _customerName,
                CustomerPhone: _customerPhone,
                CustomerAddress: _customerAddress,
                items: _items.Select(i => new CreateOrderItemDto(i.Product.Id, i.Quantity, i.Observation)).ToList()
            );

            var order = await OrderService.CreateAsync(dto);
            Snackbar.Add($"Pedido {order.Id.ToString()[..8]} criado com sucesso!", Severity.Success);
            ClearOrder();
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Erro ao criar pedido: {ex.Message}", Severity.Error);
        }
    }

    private async Task SelectExistingCustomer(Customer customer)
    {
        _customerId = customer.Id;
    }

    private void UseExistingCustomerChanged(bool newValue)
    {
        _useExistingCustomer = newValue;
        if (!_useExistingCustomer)
            _customerId = null;
    }

    private void UpdateTotals()
    {
        if (_items.Any())
        {
            var result = _items.CalculateSubtotalAndDiscount();
            _subtotal = result.subtotal;
            _discount = result.discountAbs;
            _total = result.total;
        }
        else
        {
            _subtotal = _discount = _total = 0;
        }
    }
}